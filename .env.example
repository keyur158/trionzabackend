DATABASE_URL="postgresql://trionza_user:changeme@localhost:5432/trionza_diamond"
PORT=3000
JWT_SECRET=change-me-to-a-256-bit-random-string
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxxxx
SHOPIFY_API_SECRET_KEY=xxxxx
SHOPIFY_WEBHOOK_SECRET=xxxxx
SHOPIFY_API_VERSION=2025-10
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_SECRET=your-paypal-secret
PAYPAL_MODE=sandbox
ZEPTOMAIL_TOKEN=
# Region-bound: .com (US, default), .eu (Europe), .in (India). Must match where the token was created.
ZEPTOMAIL_API_BASE=https://api.zeptomail.in
ZEPTOMAIL_FROM_ADDRESS=noreply@trionzadiamond.com
ZEPTOMAIL_FROM_NAME=Trionza Diamond
# Inbox that receives appointment + custom-order notifications.
APP_PUBLIC_URL=https://trionzadiamond.com
FIREBASE_SERVICE_ACCOUNT=./firebase-service-account.json
SYNC_INTERVAL_HOURS=6
